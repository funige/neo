{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "None",
    "allowJs": true,
    "checkJs": true, // JSファイルのチェックを有効化
    "noImplicitAny": false, // 型が不明な場合にanyを許容する
    // "noUnusedLocals": false // 未使用変数の警告を消す
  },
    "files": [
    "src/container.js",
    "src/dictionary.js",
    "src/painter.js",
    "src/tools.js",
    "src/commands.js",
    "src/actions.js",
    "src/widgets.js",
    "src/lz-string.js"
  ],
  "include": [
    "src/*.*",
    "dist/neo.js"
  ],
  "exclude": [
      "node_modules",
      "**/node_modules/*",
      "Design/*",
      "docs/*",
      "dist/PaintBBS*",
      ".git"
    ]
}